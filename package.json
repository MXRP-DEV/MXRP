{
  "name": "discord-monorepo",
  "version": "1.0.0",
  "description": "Discord bot monorepo with Turborepo",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "check": "pnpm lint && pnpm format:check",
    "fix": "pnpm lint -- --fix && pnpm format",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=25.6.1"
  },
  "devDependencies": {
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.10"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
